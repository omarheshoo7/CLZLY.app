NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=30s
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=clzly_refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
MAX_VIDEO_SIZE_MB=50

# PostgreSQL database used by Prisma.
DATABASE_URL=postgresql://omarhesham77@localhost:5432/clzly_dev
