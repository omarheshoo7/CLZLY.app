NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173
JWT_ACCESS_SECRET=development-access-secret-change-me
JWT_REFRESH_SECRET=development-refresh-secret-change-me
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=clzly_refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
MAX_VIDEO_SIZE_MB=50

# Future Feature 01 database setup. Not used in Feature 00.
DATABASE_URL=postgresql://username:password@localhost:5432/clzly_dev
