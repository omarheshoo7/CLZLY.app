NODE_ENV=staging
PORT=3000
CLIENT_URL=https://staging.clzly.example
JWT_ACCESS_SECRET=staging-access-secret-change-me
JWT_REFRESH_SECRET=staging-refresh-secret-change-me
ACCESS_TOKEN_EXPIRES_IN=30s
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=clzly_refresh_token
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
MAX_VIDEO_SIZE_MB=50

# Separate PostgreSQL database for staging later.
DATABASE_URL=postgresql://username:password@staging-db-host:5432/clzly_staging
